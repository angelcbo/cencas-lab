# ─── Cenicast LIS — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
# Production values must come from a secrets manager or CI/CD environment injection.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=cenicast_lis
DB_URL=jdbc:postgresql://localhost:5432/cenicast_lis
DB_USER=cenicast
DB_PASSWORD=cenicast

# ─── Spring ───────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# HS256 secret — must be at least 32 characters in production.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=dev-secret-key-change-in-production-must-be-at-least-32-chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Cookie (refresh token) ───────────────────────────────────────────────────
# Dev: Secure=false, SameSite=Lax, Domain=localhost
# Prod: Secure=true, SameSite=Strict, Domain=app.cenicast.com
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=localhost

# ─── App domain (production only) ─────────────────────────────────────────────
APP_DOMAIN=app.cenicast.com

# ─── pgAdmin (optional, only when using --profile tools) ──────────────────────
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
